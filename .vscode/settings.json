{
  "python.defaultInterpreterPath": "${workspaceFolder}/apps/api/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "oxc.configPath": "apps/web/.oxlintrc.json",
  "oxc.fmt.configPath": "apps/web/.oxfmtrc.json",
  "oxc.tsConfigPath": "apps/web/tsconfig.json",
  "oxc.lint.run": "onType",
  "oxc.requireConfig": true,
  "editor.formatOnSaveMode": "file",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.format.oxc": "explicit",
      "source.fixAll.oxc": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.format.oxc": "explicit",
      "source.fixAll.oxc": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.format.oxc": "explicit",
      "source.fixAll.oxc": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.format.oxc": "explicit",
      "source.fixAll.oxc": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.format.oxc": "explicit"
    }
  },
  "ruff.nativeServer": "on",
  "python-envs.pythonProjects": [
    {
      "path": "apps/api",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ]
}
